---
import Base from '../../../layouts/Base.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import ConfigDoc from '../../../components/ConfigDoc.astro';
import data from '../../../data/modules.json';

export function getStaticPaths() {
	return data.modules.map((mod) => ({ params: { ns: mod.ns, name: mod.name }, props: { mod } }));
}

const { mod } = Astro.props;
const versions = mod.engineVersions;
const platformLabel = (t) =>
	t.replace('aarch64', 'arm64').replace('x86_64', 'x86_64').replace('-apple-darwin', ' · macOS').replace('-unknown-linux-gnu', ' · Linux');
---

<Base title={`${mod.title} — doze registry`} description={mod.tagline || mod.description}>
	<div class="mx-auto max-w-6xl px-6 py-10">
		<nav class="mono text-xs text-faint">
			<a href="/registry/" class="hover:text-amber transition">modules</a>
			<span class="mx-1.5">/</span><span class="text-dim">{mod.source}</span>
		</nav>

		<!-- Header -->
		<div class="mt-6 flex items-start gap-5">
			<span class="grid place-items-center w-14 h-14 shrink-0 rounded-xl border border-line2 bg-raise2 font-display text-3xl text-amber">
				{(mod.title || mod.name)[0].toUpperCase()}
			</span>
			<div class="flex-1 min-w-0">
				<div class="flex items-center gap-3 flex-wrap">
					<h1 class="t-h1">{mod.title}</h1>
					{mod.official && <span class="mono text-[10px] uppercase tracking-wider text-amber border border-amber/40 rounded px-1.5 py-0.5">official</span>}
					{mod.signed && <span class="mono text-[10px] uppercase tracking-wider text-awake border border-awake/30 rounded px-1.5 py-0.5">● signed</span>}
				</div>
				<code class="mono text-sm text-dim">{mod.source}</code>
				{mod.version && (
					<div class="mt-1 mono text-xs text-faint">
						module v{mod.version}{mod.protocol && <span> · plugin protocol {mod.protocol}</span>}
					</div>
				)}
			</div>
		</div>

		<p class="mt-6 max-w-2xl text-dim leading-relaxed">{mod.description || mod.tagline}</p>

		<div class="mt-10 grid gap-12 lg:grid-cols-[1fr_17rem]">
			<!-- Main -->
			<div class="min-w-0 order-2 lg:order-1">
				<!-- Usage -->
				<h2 class="t-eyebrow">Usage</h2>
				<p class="mt-2 mb-3 text-sm text-dim">Drop it in <span class="mono text-faint">doze.hcl</span> and run <span class="mono text-faint">doze up</span>.</p>
				{mod.example && <CodeBlock code={mod.example} file="doze.hcl" />}

				<!-- Engine versions -->
				{versions && (
					<div class="mt-12">
						<h2 class="t-eyebrow">Engine versions</h2>
						<p class="mt-2 text-sm text-dim">
							Choose one with <span class="mono text-amber">version =</span> — the only version you
							ever write. doze fetches & verifies the engine, then pins it in
							<span class="mono text-faint">doze.lock</span>. The module release providing it is
							selected automatically (newest compatible with your doze and the versions you declared)
							and pinned alongside.
						</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							{versions.map((v) => <span class="mono text-sm rounded-md border border-line2 bg-raise px-2.5 py-1 text-fg">{v}</span>)}
						</div>
					</div>
				)}

				<!-- Releases -->
				{mod.releases && mod.releases.length > 0 && (
					<div class="mt-12">
						<h2 class="t-eyebrow">Releases</h2>
						<p class="mt-2 text-sm text-dim">
							Every published module release — the index is cumulative, so older releases stay
							resolvable for pinned lockfiles. doze selects the newest compatible one automatically;
							<span class="mono text-faint">modules {'{'} {mod.name} {'{'} version = "…" {'}'} {'}'}</span> pins one exactly.
						</p>
						<div class="mt-3 overflow-x-auto">
							<table class="w-full text-sm">
								<thead>
									<tr class="text-left mono text-xs text-faint border-b border-line">
										<th class="py-2 pr-4 font-normal">version</th>
										<th class="py-2 pr-4 font-normal">protocol</th>
										<th class="py-2 pr-4 font-normal">engine versions</th>
										<th class="py-2 font-normal">platforms</th>
									</tr>
								</thead>
								<tbody>
									{mod.releases.map((r) => (
										<tr class="border-b border-line/50">
											<td class="py-2 pr-4 mono text-fg whitespace-nowrap">
												{r.version}
												{r.stable && <span class="ml-2 mono text-[10px] uppercase tracking-wider text-awake border border-awake/30 rounded px-1.5 py-0.5">stable</span>}
											</td>
											<td class="py-2 pr-4 mono text-dim">{r.protocol}</td>
											<td class="py-2 pr-4 mono text-dim">{r.engines.join(' · ')}</td>
											<td class="py-2 mono text-xs text-faint whitespace-nowrap">{r.platforms.length} platform{r.platforms.length === 1 ? '' : 's'}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
				)}

				<!-- Configuration -->
				<div class="mt-12">
					<h2 class="t-eyebrow">Configuration</h2>
					<p class="mt-2 mb-5 text-sm text-dim">
						Arguments and nested blocks the engine accepts — generated from the module itself, so it
						can't drift.
					</p>
					<ConfigDoc config={mod.config} />
				</div>
			</div>

			<!-- Sticky rail -->
			<aside class="order-1 lg:order-2">
				<div class="lg:sticky lg:top-24 space-y-6">
					<div class="panel p-4">
						<h3 class="t-label mb-3">Add to your stack</h3>
						<CodeBlock code={`${mod.name} "${(mod.example.match(/"([^"]+)"/) || [null, mod.name])[1]}" {${versions ? `\n  version = ${versions[versions.length - 1]}` : ''}${mod.port ? `\n  port    = ${mod.port}` : ''}\n}`} />
						<p class="mt-3 mono text-xs text-faint leading-relaxed">
							default source <span class="text-dim">{mod.source}</span> — no install step; doze fetches it on <span class="text-dim">doze up</span>.
						</p>
					</div>

					<!-- The door for visitors who landed here without doze installed. -->
					<div class="panel p-4">
						<h3 class="t-label mb-3">New to doze?</h3>
						<p class="text-sm text-dim leading-relaxed mb-3">
							One binary runs this and every module here — no Docker, no toolchains.
						</p>
						<CodeBlock code={`brew install doze-dev/tap/doze\ndoze init && doze up`} />
						<p class="mt-3 mono text-xs text-faint leading-relaxed">
							also: <span class="text-dim">mise use -g ubi:doze-dev/doze</span> ·
							<a class="text-dim hover:text-amber transition" href="https://github.com/doze-dev/doze#install">all install options ↗</a>
						</p>
					</div>

					<dl class="text-sm space-y-3 px-1">
						<div class="flex justify-between gap-3"><dt class="text-faint">Category</dt><dd class="capitalize">{mod.category}</dd></div>
						<div class="flex justify-between gap-3"><dt class="text-faint">Publisher</dt><dd class="mono text-xs">{mod.ns}{mod.official ? ' · official' : ''}</dd></div>
						<div class="flex justify-between gap-3"><dt class="text-faint">Signature</dt><dd class="text-awake mono text-xs">{mod.signed ? '● ed25519' : 'unsigned'}</dd></div>
					</dl>

					<div class="px-1">
						<h3 class="t-label mb-2">Platforms</h3>
						<ul class="space-y-1 mono text-xs text-dim">
							{mod.platforms.map((p) => <li>{platformLabel(p)}</li>)}
						</ul>
					</div>

					<div class="panel p-4">
						<h3 class="t-label mb-2">Updates</h3>
						<p class="text-sm text-dim leading-relaxed">
							Pins never move on their own. When a new release ships:
						</p>
						<div class="mt-2 mono text-xs text-fg bg-raise border border-line2 rounded-md px-2.5 py-1.5">doze modules upgrade {mod.name}</div>
						<p class="mt-2 mono text-xs text-faint leading-relaxed">
							then commit <span class="text-dim">doze.lock</span> · CI: <span class="text-dim">upgrade --check</span>
						</p>
					</div>

					<div class="px-1 space-y-1.5 text-sm border-t border-line pt-4">
						{mod.sourceRepo && <a class="block text-dim hover:text-amber transition" href={mod.sourceRepo}>Source repository ↗</a>}
						{mod.homepage && <a class="block text-dim hover:text-amber transition" href={mod.homepage}>Module home ↗</a>}
						<a class="block text-faint hover:text-fg transition mono text-xs pt-1" href={mod.indexUrl}>raw index.yaml ↗</a>
						<a class="block text-faint hover:text-fg transition mono text-xs" href={mod.indexUrl.replace('index.yaml', 'meta.yaml')}>raw meta.yaml ↗</a>
					</div>
				</div>
			</aside>
		</div>
	</div>
</Base>

<script>
	for (const btn of document.querySelectorAll('[data-copy]')) {
		btn.addEventListener('click', async () => {
			await navigator.clipboard.writeText(btn.getAttribute('data-copy') || '');
			const t = btn.textContent;
			btn.textContent = 'copied';
			setTimeout(() => (btn.textContent = t), 1200);
		});
	}
</script>
