---
import Base from '../../../layouts/Base.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import data from '../../../data/modules.json';

export function getStaticPaths() {
	return data.modules.map((mod) => ({ params: { ns: mod.ns, name: mod.name }, props: { mod } }));
}

const { mod } = Astro.props;
const versions = mod.engineVersions;
---

<Base title={`${mod.title} — doze registry`} description={mod.tagline || mod.description}>
	<div class="mx-auto max-w-4xl px-5 py-10">
		<nav class="text-sm text-zinc-400">
			<a href="/registry/" class="hover:text-ink">Modules</a> <span class="mx-1">/</span>
			<span class="text-zinc-600">{mod.source}</span>
		</nav>

		<!-- Header -->
		<div class="mt-4 flex items-start gap-4">
			<span class="grid place-items-center w-12 h-12 shrink-0 rounded-xl bg-brand/10 text-brand text-xl font-bold">
				{(mod.title || mod.name)[0].toUpperCase()}
			</span>
			<div class="flex-1">
				<div class="flex items-center gap-2 flex-wrap">
					<h1 class="text-2xl font-bold tracking-tight">{mod.title}</h1>
					{mod.official && <span class="text-[11px] uppercase tracking-wide font-semibold text-brand bg-brand/10 rounded px-1.5 py-0.5">official</span>}
					{mod.signed && <span class="text-[11px] font-semibold text-emerald-700 bg-emerald-50 rounded px-1.5 py-0.5">✓ signed</span>}
				</div>
				<code class="text-sm text-zinc-500">{mod.source}</code>
			</div>
		</div>

		<p class="mt-5 text-zinc-700 leading-relaxed">{mod.description || mod.tagline}</p>

		<div class="mt-8 grid gap-8 lg:grid-cols-[1fr_15rem]">
			<!-- Left: usage + options -->
			<div class="min-w-0">
				<h2 class="text-sm font-semibold uppercase tracking-wide text-zinc-500">Usage</h2>
				<p class="mt-1 text-sm text-zinc-600">Declare it in <code>doze.hcl</code> and run <code>doze up</code>.</p>
				{mod.example && <CodeBlock code={mod.example} />}

				{versions && (
					<>
						<h2 class="mt-8 text-sm font-semibold uppercase tracking-wide text-zinc-500">Engine versions</h2>
						<p class="mt-1 text-sm text-zinc-600">Pick one with <code>version =</code>. doze fetches & verifies it, then pins it in <code>doze.lock</code>.</p>
						<div class="mt-2 flex flex-wrap gap-1.5">
							{versions.map((v) => <span class="rounded-md border border-zinc-200 bg-white px-2 py-0.5 text-sm font-mono">{v}</span>)}
						</div>
					</>
				)}

				{mod.options?.length > 0 && (
					<>
						<h2 class="mt-8 text-sm font-semibold uppercase tracking-wide text-zinc-500">Configuration</h2>
						<table class="mt-2 w-full text-sm">
							<tbody>
								{mod.options.map((o) => (
									<tr class="border-b border-zinc-100">
										<td class="py-1.5 pr-4 font-mono text-zinc-800 whitespace-nowrap align-top">{o.name}</td>
										<td class="py-1.5 text-zinc-600">{o.desc}</td>
									</tr>
								))}
							</tbody>
						</table>
					</>
				)}
			</div>

			<!-- Right: facts -->
			<aside class="text-sm">
				<dl class="space-y-3">
					<div><dt class="text-zinc-400">Category</dt><dd class="capitalize">{mod.category}</dd></div>
					<div><dt class="text-zinc-400">Platforms</dt><dd>{mod.platforms.length} (macOS · Linux, arm64 · x86_64)</dd></div>
					<div><dt class="text-zinc-400">Signature</dt><dd>{mod.signed ? 'ed25519, verified' : 'unsigned'}</dd></div>
				</dl>
				<div class="mt-5 space-y-1.5">
					{mod.sourceRepo && <a class="block text-brand hover:underline" href={mod.sourceRepo}>Source repository →</a>}
					{mod.homepage && <a class="block text-brand hover:underline" href={mod.homepage}>Module home →</a>}
					<a class="block text-zinc-500 hover:text-ink" href={mod.indexUrl}>Raw index.yaml →</a>
				</div>
			</aside>
		</div>
	</div>
</Base>

<script>
	for (const btn of document.querySelectorAll('[data-copy]')) {
		btn.addEventListener('click', async () => {
			await navigator.clipboard.writeText(btn.getAttribute('data-copy') || '');
			const t = btn.textContent;
			btn.textContent = 'copied';
			setTimeout(() => (btn.textContent = t), 1200);
		});
	}
</script>
