---
import Base from '../../layouts/Base.astro';
import ModuleCard from '../../components/ModuleCard.astro';
import data from '../../data/modules.json';

const { modules, categories, count } = data;
---

<Base title="Modules — doze registry">
	<section class="mx-auto max-w-6xl px-6 py-14">
		<p class="t-eyebrow">Browse</p>
		<h1 class="t-h1 mt-3">Modules <span class="mono text-faint text-base">({count})</span></h1>
		<p class="mt-2 text-dim">
			Signed engine modules for doze. Open one for usage, engine versions and full config —
			or stay in the terminal: <span class="mono text-faint">doze modules search</span> ·
			<span class="mono text-faint">doze modules docs &lt;name&gt;</span>.
		</p>

		<div class="mt-7 flex flex-wrap items-center justify-between gap-4">
			<div id="filters" class="flex flex-wrap gap-2 mono text-xs">
				<button data-cat="all" class="cat-btn rounded-full border border-amber bg-amber/10 text-amber px-3.5 py-1.5">all</button>
				{categories.map((c) => (
					<button data-cat={c} class="cat-btn rounded-full border border-line2 text-dim px-3.5 py-1.5 hover:border-faint hover:text-fg transition">{c}</button>
				))}
			</div>
			<input id="search" type="search" placeholder="Search…" class="w-60 rounded-lg border border-line2 bg-raise px-3.5 py-2 text-sm mono placeholder:text-faint focus:outline-none focus:border-amber transition" />
		</div>

		<div id="grid" class="mt-7 grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
			{modules.map((mod, i) => <ModuleCard mod={mod} index={i} />)}
		</div>
		<p id="empty" class="mt-10 text-center text-sm text-faint hidden mono">no modules match.</p>
	</section>
</Base>

<script>
	const search = document.getElementById('search');
	const cards = [...document.querySelectorAll('.module-card')];
	const catBtns = [...document.querySelectorAll('.cat-btn')];
	const empty = document.getElementById('empty');
	let cat = 'all';
	function apply() {
		const q = (search?.value || '').trim().toLowerCase();
		let shown = 0;
		for (const card of cards) {
			const show = (cat === 'all' || card.dataset.category === cat) && (!q || (card.dataset.name || '').includes(q));
			card.classList.toggle('hidden', !show);
			if (show) shown++;
		}
		empty?.classList.toggle('hidden', shown > 0);
	}
	search?.addEventListener('input', apply);
	for (const btn of catBtns) {
		btn.addEventListener('click', () => {
			cat = btn.dataset.cat;
			for (const b of catBtns) {
				const on = b === btn;
				b.classList.toggle('border-amber', on);
				b.classList.toggle('bg-amber/10', on);
				b.classList.toggle('text-amber', on);
				b.classList.toggle('border-line2', !on);
				b.classList.toggle('text-dim', !on);
			}
			apply();
		});
	}
</script>
