---
import Base from '../layouts/Base.astro';
import ModuleCard from '../components/ModuleCard.astro';
import data from '../data/modules.json';

const { modules, categories, count } = data;
const engineCount = new Set(modules.flatMap((m) => m.engineVersions || [])).size;
---

<Base>
	<!-- Hero -->
	<section class="mx-auto max-w-6xl px-6 pt-20 pb-14">
		<img src="/logo-mark.png" alt="doze" class="h-12 w-auto mb-7" />
		<p class="t-eyebrow">The doze module registry</p>
		<h1 class="t-display mt-5 max-w-4xl">
			Real local services,<br />
			<span class="italic text-dim">one</span>
			<span class="mono text-amber not-italic" style="font-size:0.62em; vertical-align:0.14em;">version =</span>
			<span class="italic text-dim">away.</span>
		</h1>
		<p class="mt-6 max-w-xl text-lg text-dim">
			Signed engine modules for
			<a class="text-fg underline decoration-line2 hover:decoration-amber" href="https://github.com/doze-dev/doze">doze</a>.
			No Docker. doze fetches the plugin, verifies its signature, and boots a real
			backend on first connect — Postgres, Valkey, DocumentDB, S3/SQS/SNS and more.
		</p>

		<div class="mt-8 panel max-w-xl overflow-hidden">
			<div class="flex items-center gap-1.5 px-4 h-9 border-b border-line">
				<span class="w-2.5 h-2.5 rounded-full bg-line2"></span>
				<span class="w-2.5 h-2.5 rounded-full bg-line2"></span>
				<span class="w-2.5 h-2.5 rounded-full bg-line2"></span>
				<span class="mono text-xs text-faint ml-2">doze.hcl</span>
			</div>
			<pre class="mono text-sm leading-relaxed p-4 overflow-x-auto"><span class="text-amber">postgres</span> <span class="text-awake">"db"</span> &#123;
  version = <span class="text-amber2">18</span>
  port    = <span class="text-amber2">5432</span>
&#125;</pre>
		</div>

		<!-- The door: get doze itself, right where the modules are browsed. -->
		<div class="mt-5 max-w-xl mono text-sm text-dim flex flex-wrap items-center gap-x-3 gap-y-1">
			<span class="text-faint select-none">$</span>
			<span>brew install <span class="text-amber">doze-dev/tap/doze</span></span>
			<span class="text-faint">·</span>
			<a class="text-faint hover:text-amber transition text-xs" href="https://github.com/doze-dev/doze#install">more install options ↗</a>
		</div>

		<div class="mt-8 flex flex-wrap gap-x-8 gap-y-2 t-label">
			<span><span class="text-fg mono text-sm">{count}</span> modules</span>
			<span><span class="text-fg mono text-sm">{engineCount}</span> engine versions</span>
			<span><span class="text-awake mono text-sm">●</span> all signed</span>
		</div>
	</section>

	<!-- Modules -->
	<section id="modules" class="mx-auto max-w-6xl px-6 pb-8 border-t border-line pt-12">
		<div class="flex flex-wrap items-end justify-between gap-4">
			<div>
				<h2 class="t-h1">Modules</h2>
				<p class="mt-1 text-sm text-dim">Pick an engine. Declare it. <span class="mono text-faint">doze up</span>.</p>
			</div>
			<input
				id="search"
				type="search"
				placeholder="Search modules…"
				class="w-60 rounded-lg border border-line2 bg-raise px-3.5 py-2 text-sm mono placeholder:text-faint focus:outline-none focus:border-amber transition"
			/>
		</div>

		<div id="filters" class="mt-6 flex flex-wrap gap-2 mono text-xs">
			<button data-cat="all" class="cat-btn rounded-full border border-amber bg-amber/10 text-amber px-3.5 py-1.5">all</button>
			{categories.map((c) => (
				<button data-cat={c} class="cat-btn rounded-full border border-line2 text-dim px-3.5 py-1.5 hover:border-faint hover:text-fg transition">{c}</button>
			))}
		</div>

		<div id="grid" class="mt-7 grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
			{modules.map((mod, i) => <ModuleCard mod={mod} index={i} />)}
		</div>
		<p id="empty" class="mt-10 text-center text-sm text-faint hidden mono">no modules match.</p>
	</section>
</Base>

<script>
	const search = document.getElementById('search');
	const cards = [...document.querySelectorAll('.module-card')];
	const catBtns = [...document.querySelectorAll('.cat-btn')];
	const empty = document.getElementById('empty');
	let cat = 'all';
	function apply() {
		const q = (search?.value || '').trim().toLowerCase();
		let shown = 0;
		for (const card of cards) {
			const show = (cat === 'all' || card.dataset.category === cat) && (!q || (card.dataset.name || '').includes(q));
			card.classList.toggle('hidden', !show);
			if (show) shown++;
		}
		empty?.classList.toggle('hidden', shown > 0);
	}
	search?.addEventListener('input', apply);
	for (const btn of catBtns) {
		btn.addEventListener('click', () => {
			cat = btn.dataset.cat;
			for (const b of catBtns) {
				const on = b === btn;
				b.classList.toggle('border-amber', on);
				b.classList.toggle('bg-amber/10', on);
				b.classList.toggle('text-amber', on);
				b.classList.toggle('border-line2', !on);
				b.classList.toggle('text-dim', !on);
			}
			apply();
		});
	}
</script>
