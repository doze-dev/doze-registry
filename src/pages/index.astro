---
import Base from '../layouts/Base.astro';
import ModuleCard from '../components/ModuleCard.astro';
import data from '../data/modules.json';

const { modules, categories, count } = data;
---

<Base>
	<!-- Hero -->
	<section class="border-b border-zinc-200/70 bg-gradient-to-b from-white to-paper">
		<div class="mx-auto max-w-5xl px-5 py-16 text-center">
			<p class="text-sm font-medium text-brand">The doze module registry</p>
			<h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight">
				Real local services, one <code class="text-brand">version =</code> away.
			</h1>
			<p class="mt-4 max-w-2xl mx-auto text-lg text-zinc-600">
				Signed engine modules for <a class="text-brand hover:underline" href="https://github.com/doze-dev/doze">doze</a> —
				Postgres, Valkey, DocumentDB, S3/SQS/SNS and more. No Docker. doze fetches the
				plugin, verifies its signature, and boots a real backend on first connect.
			</p>
			<div class="mt-6 inline-flex items-center gap-2 rounded-lg border border-zinc-200 bg-white px-4 py-2 font-mono text-sm text-zinc-700">
				<span class="text-zinc-400">$</span> postgres "db" &#123; version = 18 &#125;
			</div>
		</div>
	</section>

	<!-- Modules -->
	<section id="modules" class="mx-auto max-w-5xl px-5 py-12">
		<div class="flex flex-wrap items-center justify-between gap-3">
			<h2 class="text-xl font-semibold tracking-tight">Modules <span class="text-zinc-400 font-normal">({count})</span></h2>
			<input
				id="search"
				type="search"
				placeholder="Search modules…"
				class="w-56 rounded-lg border border-zinc-200 bg-white px-3 py-1.5 text-sm focus:outline-none focus:border-brand"
			/>
		</div>

		<div id="filters" class="mt-4 flex flex-wrap gap-2 text-sm">
			<button data-cat="all" class="cat-btn rounded-full border border-brand bg-brand text-white px-3 py-1">All</button>
			{categories.map((c) => (
				<button data-cat={c} class="cat-btn rounded-full border border-zinc-200 px-3 py-1 capitalize hover:border-brand">{c}</button>
			))}
		</div>

		<div id="grid" class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{modules.map((mod) => <ModuleCard mod={mod} />)}
		</div>
		<p id="empty" class="mt-8 text-center text-sm text-zinc-400 hidden">No modules match.</p>
	</section>
</Base>

<script>
	const search = document.getElementById('search');
	const cards = [...document.querySelectorAll('.module-card')];
	const catBtns = [...document.querySelectorAll('.cat-btn')];
	const empty = document.getElementById('empty');
	let cat = 'all';

	function apply() {
		const q = (search?.value || '').trim().toLowerCase();
		let shown = 0;
		for (const card of cards) {
			const okCat = cat === 'all' || card.dataset.category === cat;
			const okText = !q || (card.dataset.name || '').includes(q);
			const show = okCat && okText;
			card.classList.toggle('hidden', !show);
			if (show) shown++;
		}
		empty?.classList.toggle('hidden', shown > 0);
	}

	search?.addEventListener('input', apply);
	for (const btn of catBtns) {
		btn.addEventListener('click', () => {
			cat = btn.dataset.cat;
			for (const b of catBtns) {
				const active = b === btn;
				b.classList.toggle('bg-brand', active);
				b.classList.toggle('text-white', active);
				b.classList.toggle('border-brand', active);
				b.classList.toggle('border-zinc-200', !active);
			}
			apply();
		});
	}
</script>
