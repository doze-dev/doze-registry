---
import '../styles/global.css';
const { title = 'doze registry', description = 'Signed engine modules for doze — real local databases & AWS services, no Docker.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#23242d" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="https://doze.nerdmenot.in/og.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="https://doze.nerdmenot.in/og.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<script is:inline>
			// Theme init, before paint. Shares the docs site's localStorage key
			// ('starlight-theme') so flipping the switch on either half of
			// doze.nerdmenot.in flips both.
			(() => {
				const stored = localStorage.getItem('starlight-theme');
				const theme =
					stored === 'light' || stored === 'dark'
						? stored
						: matchMedia('(prefers-color-scheme: light)').matches
							? 'light'
							: 'dark';
				document.documentElement.dataset.theme = theme;
			})();
		</script>
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="sticky top-0 z-30 border-b border-line bg-ink/80 backdrop-blur-md">
			<div class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between">
				<a href="/" class="group flex items-center gap-2.5">
					<img src="/logo-mark.png" alt="doze" class="h-7 w-auto transition group-hover:opacity-80" />
					<span class="mono text-sm tracking-tight">doze<span class="text-faint">/registry</span></span>
				</a>
				<nav class="flex items-center gap-7 text-sm text-dim">
					<a href="/" class="hover:text-fg transition">Docs</a>
					<a href="/registry/" class="hover:text-fg transition">Modules</a>
					<a href="https://github.com/doze-dev/doze" class="hover:text-fg transition">GitHub</a>
					<a href="https://github.com/doze-dev/doze-registry" class="mono text-xs px-3 py-1.5 rounded-md border border-line2 text-fg hover:border-amber hover:text-amber transition">Publish</a>
					<div
						id="theme-seg"
						role="radiogroup"
						aria-label="Color theme"
						class="inline-flex items-center gap-0.5 p-0.5 rounded-lg border border-line2 bg-raise2"
					>
						<button type="button" data-pref="auto" role="radio" aria-label="System theme" title="System" class="grid place-items-center w-7 h-6 rounded-md text-faint transition">
							<svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M4 5h16a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1h-6l1 2h2a1 1 0 1 1 0 2H7a1 1 0 1 1 0-2h2l1-2H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm1 2v7h14V7H5Z"/></svg>
						</button>
						<button type="button" data-pref="light" role="radio" aria-label="Light theme" title="Light" class="grid place-items-center w-7 h-6 rounded-md text-faint transition">
							<svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0-5a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 17a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1ZM3 11a1 1 0 1 1 0 2H2a1 1 0 1 1 0-2h1Zm19 0a1 1 0 1 1 0 2h-1a1 1 0 1 1 0-2h1ZM5.6 4.2 6.3 5a1 1 0 0 1-1.4 1.4l-.7-.7A1 1 0 0 1 5.6 4.2Zm12.7 12.7.7.7a1 1 0 0 1-1.4 1.4l-.7-.7a1 1 0 0 1 1.4-1.4ZM4.2 18.4l.7-.7A1 1 0 0 1 6.3 19l-.7.7a1 1 0 0 1-1.4-1.3Zm12.7-12.7.7-.7a1 1 0 1 1 1.4 1.4l-.7.7a1 1 0 0 1-1.4-1.4Z"/></svg>
						</button>
						<button type="button" data-pref="dark" role="radio" aria-label="Dark theme" title="Dark" class="grid place-items-center w-7 h-6 rounded-md text-faint transition">
							<svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12.7 2.4a1 1 0 0 1 .2 1.1 7 7 0 0 0 9.2 9.2 1 1 0 0 1 1.3 1.3A9 9 0 1 1 11.6 2.2a1 1 0 0 1 1.1.2Z"/></svg>
						</button>
					</div>
				</nav>
			</div>
		</header>

		<main class="flex-1">
			<slot />
		</main>

		<footer class="border-t border-line mt-24">
			<div class="mx-auto max-w-6xl px-6 py-10 flex flex-wrap items-center gap-x-8 gap-y-3 justify-between text-sm text-faint">
				<span class="flex items-center gap-2">
					<span class="text-awake">●</span>
					Every module is ed25519-signed and pinned on first use.
				</span>
				<span class="mono text-xs">doze.nerdmenot.in</span>
			</div>
		</footer>
		<script is:inline>
			// Three-way theme control, sharing the docs site's storage
			// ('starlight-theme' = 'light' | 'dark' | '' for system) so flipping
			// on either half of doze.nerdmenot.in flips both.
			(() => {
				const KEY = 'starlight-theme';
				const seg = document.getElementById('theme-seg');
				if (!seg) return;
				const buttons = [...seg.querySelectorAll('button')];
				const loadPref = () => {
					const v = localStorage.getItem(KEY);
					return v === 'light' || v === 'dark' ? v : 'auto';
				};
				const systemPref = () =>
					matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
				const apply = (pref) => {
					document.documentElement.dataset.theme = pref === 'auto' ? systemPref() : pref;
					localStorage.setItem(KEY, pref === 'light' || pref === 'dark' ? pref : '');
					for (const b of buttons) {
						const on = b.dataset.pref === pref;
						b.setAttribute('aria-checked', String(on));
						b.classList.toggle('seg-active', on);
					}
				};
				for (const b of buttons) b.addEventListener('click', () => apply(b.dataset.pref));
				matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
					if (loadPref() === 'auto') apply('auto');
				});
				apply(loadPref());
			})();
		</script>
	</body>
</html>
