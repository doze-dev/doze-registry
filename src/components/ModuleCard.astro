---
const { mod } = Astro.props;
const versions = mod.engineVersions ? mod.engineVersions.join(' · ') : 'built-in';
const initial = (mod.title || mod.name)[0].toUpperCase();
---

<a
	href={`/registry/${mod.source}/`}
	class="module-card group block rounded-xl border border-zinc-200 bg-white p-4 hover:border-brand hover:shadow-sm transition"
	data-name={`${mod.source} ${mod.title} ${mod.tagline} ${mod.category}`.toLowerCase()}
	data-category={mod.category}
>
	<div class="flex items-start gap-3">
		<span class="grid place-items-center w-9 h-9 shrink-0 rounded-lg bg-zinc-100 text-zinc-600 font-semibold group-hover:bg-brand/10 group-hover:text-brand">
			{initial}
		</span>
		<div class="min-w-0 flex-1">
			<div class="flex items-center gap-2">
				<span class="font-semibold tracking-tight truncate">{mod.title}</span>
				{mod.official && <span class="text-[10px] uppercase tracking-wide font-semibold text-brand bg-brand/10 rounded px-1.5 py-0.5">official</span>}
			</div>
			<code class="text-xs text-zinc-400">{mod.source}</code>
		</div>
		{mod.signed && <span title="signed by the publisher key" class="text-emerald-600 text-sm shrink-0">✓</span>}
	</div>
	<p class="mt-2 text-sm text-zinc-600 line-clamp-2">{mod.tagline || mod.description}</p>
	<div class="mt-3 flex items-center gap-2 text-xs text-zinc-500">
		<span class="rounded bg-zinc-100 px-1.5 py-0.5 capitalize">{mod.category}</span>
		<span class="text-zinc-400">{versions}</span>
	</div>
</a>
