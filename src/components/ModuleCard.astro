---
const { mod, index = 0 } = Astro.props;
const versions = mod.engineVersions ? mod.engineVersions.join(' · ') : 'built-in';
const initial = (mod.title || mod.name)[0].toUpperCase();
---

<a
	href={`/registry/${mod.source}/`}
	class="module-card group relative block panel p-5 hover:border-line2 transition-colors"
	style={`animation-delay:${Math.min(index * 45, 400)}ms`}
	data-name={`${mod.source} ${mod.title} ${mod.tagline} ${mod.category}`.toLowerCase()}
	data-category={mod.category}
>
	<div class="flex items-start gap-3.5">
		<span class="grid place-items-center w-10 h-10 shrink-0 rounded-lg border border-line2 bg-raise2 font-display text-xl text-amber group-hover:border-amber/50 transition">
			{initial}
		</span>
		<div class="min-w-0 flex-1">
			<div class="flex items-center gap-2">
				<span class="t-h2 truncate">{mod.title}</span>
				{mod.official && <span class="mono text-[9px] uppercase tracking-wider text-amber/90">official</span>}
			</div>
			<code class="mono text-xs text-faint">{mod.source}</code>
		</div>
		{mod.signed && <span title="signed" class="text-awake text-xs shrink-0 mt-1">●</span>}
	</div>
	<p class="mt-3 text-sm text-dim leading-snug line-clamp-2">{mod.tagline || mod.description}</p>
	<div class="mt-4 pt-3 border-t border-line flex items-center justify-between mono text-xs">
		<span class="text-faint capitalize">{mod.category}</span>
		<span class="text-dim">{versions}</span>
	</div>
	<span class="absolute right-5 top-5 text-faint opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0 transition">→</span>
</a>

<style>
	.module-card {
		opacity: 0;
		animation: card-in 0.5s cubic-bezier(0.2, 0.7, 0.3, 1) forwards;
	}
	@keyframes card-in {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}
	@media (prefers-reduced-motion: reduce) {
		.module-card { animation: none; opacity: 1; }
	}
</style>
