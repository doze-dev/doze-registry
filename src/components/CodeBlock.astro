---
const { code, file } = Astro.props;
---

<div class="relative group panel overflow-hidden">
	{file && (
		<div class="flex items-center gap-1.5 px-4 h-9 border-b border-line">
			<span class="w-2.5 h-2.5 rounded-full bg-line2"></span>
			<span class="w-2.5 h-2.5 rounded-full bg-line2"></span>
			<span class="w-2.5 h-2.5 rounded-full bg-line2"></span>
			<span class="mono text-xs text-faint ml-2">{file}</span>
		</div>
	)}
	<pre class="mono text-sm leading-relaxed p-4 overflow-x-auto text-fg"><code>{code}</code></pre>
	<button
		data-copy={code}
		class="absolute top-2.5 right-2.5 rounded-md border border-line2 bg-raise2 text-faint mono text-xs px-2 py-1 opacity-0 group-hover:opacity-100 hover:text-amber hover:border-amber/50 transition"
		aria-label="Copy"
	>copy</button>
</div>
